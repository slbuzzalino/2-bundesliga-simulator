generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Simulation {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String?
  results   String   // JSON string of simulated results { matchId: "homeScore-awayScore" }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Match {
  id            Int      @id // football-data.org match ID
  matchday      Int
  homeTeamId    Int
  homeTeamName  String
  homeTeamCrest String?
  awayTeamId    Int
  awayTeamName  String
  awayTeamCrest String?
  homeScore     Int?
  awayScore     Int?
  status        String   // SCHEDULED, LIVE, IN_PLAY, PAUSED, FINISHED, POSTPONED, etc.
  utcDate       DateTime
  updatedAt     DateTime @updatedAt
}

model Standing {
  id               Int    @id @default(autoincrement())
  teamId           Int    @unique
  teamName         String
  teamCrest        String?
  position         Int
  playedGames      Int
  won              Int
  draw             Int
  lost             Int
  points           Int
  goalsFor         Int
  goalsAgainst     Int
  goalDifference   Int
  updatedAt        DateTime @updatedAt
}
